{
    "name": "nest",
    "version": "0.2.0",
    "private": true,
    "description": "Minimal agent gateway kernel — sessions, plugins, cron, HTTP",
    "type": "module",
    "license": "MIT",
    "engines": {
        "node": ">=22.0.0"
    },
    "bin": {
        "nest": "./dist/cli.js"
    },
    "scripts": {
        "prepare": "tsc",
        "build": "tsc",
        "nest": "tsx src/cli.ts",
        "dev": "tsx src/cli.ts start",
        "start": "node dist/cli.js start",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@clack/prompts": "^1.1.0",
        "@mariozechner/pi-tui": "^0.57.1",
        "discord.js": "^13.17.1",
        "figlet": "^1.10.0",
        "gray-matter": "^4.0.3",
        "js-yaml": "^4.1.1",
        "matrix-bot-sdk": "^0.8.0",
        "node-cron": "^4.2.1",
        "sharp": "^0.34.5",
        "ws": "^8.19.0"
    },
    "devDependencies": {
        "@types/figlet": "^1.7.0",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^25.2.3",
        "@types/node-cron": "^3.0.11",
        "@types/ws": "^8.18.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    },
    "overrides": {
        "form-data": ">=2.5.4",
        "qs": ">=6.14.1",
        "tough-cookie": ">=4.1.3"
    }
}
